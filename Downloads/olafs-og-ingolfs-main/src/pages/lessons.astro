---
import Layout from '../layouts/Layout.astro'
import {getSiteSettings} from '../lib/sanity'

const showKids = import.meta.env.PUBLIC_SHOW_KIDS === 'true'

if (!showKids) {
  return Astro.redirect('/safnadarstarf')
}

const siteSettings = await getSiteSettings()
const title = siteSettings?.canonicalName ?? siteSettings?.publicName ?? 'Ólafsvík & Ingjaldshóll'
---

<Layout title={`${title} - Námskeið fyrir börn`}>
  <main class="min-h-screen bg-gray-50">
    <div class="container mx-auto px-4 py-16">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold text-gray-900 mb-4">Námskeið fyrir börn</h1>
        <p class="text-xl text-gray-600">Kennsluefni og námskeið</p>
      </div>

      <div class="max-w-4xl mx-auto">
        <div class="space-y-8">
          <div class="bg-purple-50 rounded-lg shadow-md p-8 border-l-4 border-purple-500">
            <div class="flex items-center mb-6">
              <svg class="w-10 h-10 text-purple-600 mr-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
              </svg>
              <div>
                <h2 class="text-2xl font-bold text-gray-900">Grunnnám í kristinni trú</h2>
                <p class="text-gray-600">Fyrir börn 6-12 ára</p>
              </div>
            </div>
            
            <div class="space-y-6">
              <div class="bg-white rounded-lg p-6">
                <h3 class="text-lg font-semibold text-gray-900 mb-3">Námskeið 1: Kynning á Biblíunni</h3>
                <p class="text-gray-700 mb-4">
                  Lærðu um byggingu Biblíunnar, helgustu sögur persónurnar og hvernig hún varð til.
                </p>
                <div class="grid gap-3 md:grid-cols-2">
                  <div class="flex items-center">
                    <svg class="w-5 h-5 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    <span class="text-gray-700">5 kennslustundir</span>
                  </div>
                  <div class="flex items-center">
                    <svg class="w-5 h-5 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    <span class="text-gray-700">Verkefni og skemmtiðir</span>
                  </div>
                  <div class="flex items-center">
                    <svg class="w-5 h-5 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    <span class="text-gray-700">Myndir og myndbönd</span>
                  </div>
                  <div class="flex items-center">
                    <svg class="w-5 h-5 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    <span class="text-gray-700">Lokapróf</span>
                  </div>
                </div>
              </div>

              <div class="bg-white rounded-lg p-6">
                <h3 class="text-lg font-semibold text-gray-900 mb-3">Námskeið 2: Lífs Jesú</h3>
                <p class="text-gray-700 mb-4">
                  Kynntu þér við líf Jesú, kennslu hans, undurverk og þau mikilvægu atburði sem breyttu heiminum.
                </p>
                <div class="grid gap-3 md:grid-cols-2">
                  <div class="flex items-center">
                    <svg class="w-5 h-5 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    <span class="text-gray-700">8 kennslustundir</span>
                  </div>
                  <div class="flex items-center">
                    <svg class="w-5 h-5 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    <span class="text-gray-700">Sögur og dæmi</span>
                  </div>
                  <div class="flex items-center">
                    <svg class="w-5 h-5 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    <span class="text-gray-700">Samstarfsverkefni</span>
                  </div>
                  <div class="flex items-center">
                    <svg class="w-5 h-5 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    <span class="text-gray-700">Verkefnabók</span>
                  </div>
                </div>
              </div>

              <div class="bg-white rounded-lg p-6">
                <h3 class="text-lg font-semibold text-gray-900 mb-3">Námskeið 3: Fyrstu kristnir</h3>
                <p class="text-gray-700 mb-4">
                  Lærðu um fyrstu kristnu, postula og upphaf kirkjunnar í Rómaveldi.
                </p>
                <div class="grid gap-3 md:grid-cols-2">
                  <div class="flex items-center">
                    <svg class="w-5 h-5 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    <span class="text-gray-700">6 kennslustundir</span>
                  </div>
                  <div class="flex items-center">
                    <svg class="w-5 h-5 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    <span class="text-gray-700">Sagnfræði</span>
                  </div>
                  <div class="flex items-center">
                    <svg class="w-5 h-5 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    <span class="text-gray-700">Kort og tímalínur</span>
                  </div>
                  <div class="flex items-center">
                    <svg class="w-5 h-5 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    <span class="text-gray-700">Rannsóknarverkefni</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-purple-50 rounded-lg shadow-md p-8 border-l-4 border-purple-500">
            <div class="flex items-center mb-6">
              <svg class="w-10 h-10 text-purple-600 mr-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
              </svg>
              <div>
                <h2 class="text-2xl font-bold text-gray-900">Sérstök námskeið</h2>
                <p class="text-gray-600">Þemu- og tímaháðar námskeið</p>
              </div>
            </div>
            
            <div class="grid gap-6 md:grid-cols-2">
              <div class="bg-white rounded-lg p-6">
                <h3 class="text-lg font-semibold text-gray-900 mb-3">Páskanámskeið</h3>
                <p class="text-gray-700 mb-4">
                  Námskeið um páska, krossfest Jesú og upprisu. Hentar vel fyrir páskatímann.
                </p>
                <div class="flex items-center text-sm text-gray-600">
                  <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  4 vikur
                </div>
              </div>

              <div class="bg-white rounded-lg p-6">
                <h3 class="text-lg font-semibold text-gray-900 mb-3">Jólanámskeið</h3>
                <p class="text-gray-700 mb-4">
                  Námskeið um jólasögur, fæðingu Jesú og merking jólanna.
                </p>
                <div class="flex items-center text-sm text-gray-600">
                  <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  3 vikur
                </div>
              </div>

              <div class="bg-white rounded-lg p-6">
                <h3 class="text-lg font-semibold text-gray-900 mb-3">Bænarnámskeið</h3>
                <p class="text-gray-700 mb-4">
                  Lærðu mismunandi tegundir bæna, hvernig á að biðja og hvers vegna bænir eru mikilvægar.
                </p>
                <div class="flex items-center text-sm text-gray-600">
                  <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  2 vikur
                </div>
              </div>

              <div class="bg-white rounded-lg p-6">
                <h3 class="text-lg font-semibold text-gray-900 mb-3">Frustuðarnámskeið</h3>
                <p class="text-gray-700 mb-4">
                  Námskeið um frustuðargjöf, þakkgjörð og að deila með öðrum.
                </p>
                <div class="flex items-center text-sm text-gray-600">
                  <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  2 vikur
                </div>
              </div>
            </div>
          </div>

          <div class="bg-purple-100 border-l-4 border-purple-500 p-6">
            <h3 class="text-lg font-semibold text-purple-900 mb-2">Fyrir kennara og foreldra</h3>
            <p class="text-purple-800">
              Öll námskeið eru hönnuð með kennaraleiðbeiningum og verkefnum sem henta vel fyrir börn. 
      Þetta efni getur verið notað í sunnudagsskóla, heima eða í öðrum samkomum fyrir börn.
            </p>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>
