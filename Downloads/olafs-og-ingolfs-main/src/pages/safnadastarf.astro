---
import Layout from '../layouts/Layout.astro'
import {getSiteSettings} from '../lib/sanity'

const siteSettings = await getSiteSettings()
const title = siteSettings?.canonicalName ?? siteSettings?.publicName ?? 'Ólafsvík & Ingjaldshóll'
const showKids = import.meta.env.PUBLIC_SHOW_KIDS === 'true'
---

<Layout title={`${title} - Safnaðarstarf`}>
  <main class="min-h-screen bg-gray-50">
    <div class="container mx-auto px-4 py-16">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold text-gray-900 mb-4">Safnaðarstarf</h1>
        <p class="text-xl text-gray-600">Starfsemi og félagslíf sóknarinnar</p>
      </div>

      <div class="max-w-4xl mx-auto">
        <div class="grid gap-8 md:grid-cols-2">
          <div class="bg-white rounded-lg shadow-md p-6">
            <div class="flex items-center mb-4">
              <svg class="w-8 h-8 text-blue-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
              </svg>
              <h2 class="text-xl font-semibold text-gray-900">Sunnudagsskóli</h2>
            </div>
            <p class="text-gray-700">
              Starfsemi fyrir börn og unglinga á sunnudögum með sögum, leikjum og námskeiðum um kristna trú.
            </p>
          </div>

          <div class="bg-white rounded-lg shadow-md p-6">
            <div class="flex items-center mb-4">
              <svg class="w-8 h-8 text-blue-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
              </svg>
              <h2 class="text-xl font-semibold text-gray-900">Ungmennastarf</h2>
            </div>
            <p class="text-gray-700">
              Starfsemi fyrir ungt fólk með fundi, útferðum og samveru í kristnum andrúmsheimum.
            </p>
          </div>

          <div class="bg-white rounded-lg shadow-md p-6">
            <div class="flex items-center mb-4">
              <svg class="w-8 h-8 text-blue-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
              </svg>
              <h2 class="text-xl font-semibold text-gray-900">Kvennakaffi</h2>
            </div>
            <p class="text-gray-700">
              Regluleg kaffihús fyrir konur í sókninni með fyrirlestrum, samveru og kristnum hugsjónum.
            </p>
          </div>

          <div class="bg-white rounded-lg shadow-md p-6">
            <div class="flex items-center mb-4">
              <svg class="w-8 h-8 text-blue-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              <h2 class="text-xl font-semibold text-gray-900">Styrktarsöfnun</h2>
            </div>
            <p class="text-gray-700">
              Fjölbreytt styrktarstarf til að styðja verkefni kirkjunnar og kristilega starfsemi.
            </p>
          </div>

          {showKids && (
            <div class="bg-purple-50 rounded-lg shadow-md p-6 border-l-4 border-purple-500">
              <div class="flex items-center mb-4">
                <svg class="w-8 h-8 text-purple-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                </svg>
                <h2 class="text-xl font-semibold text-gray-900">Barnaefni</h2>
              </div>
              <p class="text-gray-700 mb-4">
                Sérstakt efni fyrir börn með sögum, myndum og skemmtilegum verkefnum.
              </p>
              <a 
                href="/barn" 
                class="inline-flex items-center text-purple-600 hover:text-purple-800 font-medium"
              >
                Skoða barnaefni
                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          )}

          {showKids && (
            <div class="bg-purple-50 rounded-lg shadow-md p-6 border-l-4 border-purple-500">
              <div class="flex items-center mb-4">
                <svg class="w-8 h-8 text-purple-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                </svg>
                <h2 class="text-xl font-semibold text-gray-900">Námskeið fyrir börn</h2>
              </div>
              <p class="text-gray-700 mb-4">
                Kennsluefni og námskeið sérstaklega hönnuð fyrir börn og yngri unga fólk.
              </p>
              <a 
                href="/lessons" 
                class="inline-flex items-center text-purple-600 hover:text-purple-800 font-medium"
              >
                Skoða námskeið
                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          )}
        </div>

        <div class="bg-blue-50 border-l-4 border-blue-500 p-6 mt-8">
          <h3 class="text-lg font-semibold text-blue-900 mb-2">Taka þátt</h3>
          <p class="text-blue-800">
            Allir eru velkomnir til að taka þátt í starfsemi sóknarinnar. Hafið samband við sóknarprest 
            ef þið hafa áhuga á að vera með eða viljað nánari upplýsingar.
          </p>
        </div>
      </div>
    </div>
  </main>
</Layout>
