---
import Layout from '../layouts/Layout.astro'
import {getSiteSettings} from '../lib/sanity'

const siteSettings = await getSiteSettings()
const title = siteSettings?.canonicalName || siteSettings?.publicName ?? 'Ólafsvík & Ingjaldshóll'
---

<Layout title={`${title} - Tengiliðir`}>
  <main class="min-h-screen bg-gray-50">
    <div class="container mx-auto px-4 py-16">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold text-gray-900 mb-4">Tengiliðir</h1>
        <p class="text-xl text-gray-600">Hafðu samband við okkur</p>
      </div>

      <div class="max-w-4xl mx-auto">
        {siteSettings?.locations && siteSettings.locations.length > 0 ? (
          <div class="grid gap-8 md:grid-cols-2">
            {siteSettings.locations.map((location) => (
              <div class="bg-white rounded-lg shadow-md p-6">
                <h2 class="text-2xl font-bold text-gray-900 mb-4">{location.name}</h2>
                
                <div class="space-y-4">
                  <div class="flex items-start">
                    <svg class="w-5 h-5 text-gray-400 mr-3 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    <div>
                      <h3 class="font-semibold text-gray-900 mb-1">Heimilisfang</h3>
                      <p class="text-gray-700 whitespace-pre-line">{location.address}</p>
                    </div>
                  </div>

                  {location.phone && (
                    <div class="flex items-start">
                      <svg class="w-5 h-5 text-gray-400 mr-3 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                      </svg>
                      <div>
                        <h3 class="font-semibold text-gray-900 mb-1">Sími</h3>
                        <a href={`tel:${location.phone}`} class="text-blue-600 hover:text-blue-800">
                          {location.phone}
                        </a>
                      </div>
                    </div>
                  )}

                  {location.email && (
                    <div class="flex items-start">
                      <svg class="w-5 h-5 text-gray-400 mr-3 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                      </svg>
                      <div>
                        <h3 class="font-semibold text-gray-900 mb-1">Netfang</h3>
                        <a href={`mailto:${location.email}`} class="text-blue-600 hover:text-blue-800">
                          {location.email}
                        </a>
                      </div>
                    </div>
                  )}

                  {location.mapLink && (
                    <div class="flex items-start">
                      <svg class="w-5 h-5 text-gray-400 mr-3 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
                      </svg>
                      <div>
                        <h3 class="font-semibold text-gray-900 mb-1">Kort</h3>
                        <a 
                          href={location.mapLink} 
                          target="_blank" 
                          rel="noopener noreferrer"
                          class="text-blue-600 hover:text-blue-800 inline-flex items-center"
                        >
                          Sjá á korti
                          <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                          </svg>
                        </a>
                      </div>
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div class="bg-white rounded-lg shadow-md p-8 text-center">
            <svg class="w-16 h-16 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <h3 class="text-xl font-semibold text-gray-900 mb-2">Engar staðsetningar skráðar</h3>
            <p class="text-gray-600">
              Engar staðsetningar hafa verið skráðar í stillingum vefsíðunnar.
            </p>
          </div>
        )}

        <div class="bg-blue-50 border-l-4 border-blue-500 p-6 mt-8">
          <h3 class="text-lg font-semibold text-blue-900 mb-2">Almennar fyrirspurnir</h3>
          <p class="text-blue-800">
            Fyrir almennar fyrirspurnir og beiðnir um athafnir, vinsamlegast hafið samband 
            í opnunartíma kirkjanna eða sendið okkur netfang.
          </p>
        </div>
      </div>
    </div>
  </main>
</Layout>
