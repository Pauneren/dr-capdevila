---
import Layout from '../layouts/Layout.astro'
import {getSiteSettings, getAnnouncements} from '../lib/sanity'

const siteSettings = await getSiteSettings()
const title = siteSettings?.canonicalName || siteSettings?.publicName ?? 'Ólafsvík & Ingjaldshóll'
const announcements = await getAnnouncements()

function formatAnnouncementDate(dateString: string) {
  const date = new Date(dateString)
  return date.toLocaleDateString('is-IS', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  })
}
---

<Layout title={`${title} - Tilkynningar`}>
  <main class="min-h-screen bg-gray-50">
    <div class="container mx-auto px-4 py-16">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold text-gray-900 mb-4">Tilkynningar</h1>
        <p class="text-xl text-gray-600">Nýjustu tilkynningar frá sókninni</p>
      </div>

      {announcements && announcements.length > 0 ? (
        <div class="max-w-4xl mx-auto">
          <div class="space-y-6">
            {announcements.map((announcement) => (
              <article class={`bg-white rounded-lg shadow-md p-6 border-l-4 ${
                announcement.pinned ? 'border-blue-500' : 'border-gray-300'
              }`}>
                <div class="flex justify-between items-start mb-4">
                  <h2 class="text-2xl font-bold text-gray-900">{announcement.title}</h2>
                  {announcement.pinned && (
                    <span class="bg-blue-100 text-blue-800 text-sm font-medium px-3 py-1 rounded-full">
                      Fest
                    </span>
                  )}
                </div>
                
                <p class="text-sm text-gray-500 mb-4">
                  {formatAnnouncementDate(announcement.date)}
                </p>
                
                <div class="prose prose-gray max-w-none">
                  <p class="text-gray-700 whitespace-pre-wrap leading-relaxed">
                    {announcement.body}
                  </p>
                </div>
                
                {announcement.link && (
                  <div class="mt-6">
                    <a 
                      href={announcement.link} 
                      class="inline-flex items-center text-blue-600 hover:text-blue-800 font-medium"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      Lesa meira
                      <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                      </svg>
                    </a>
                  </div>
                )}
              </article>
            ))}
          </div>
        </div>
      ) : (
        <div class="max-w-2xl mx-auto">
          <div class="bg-white rounded-lg shadow-md p-8 text-center">
            <svg class="w-16 h-16 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            <h3 class="text-xl font-semibold text-gray-900 mb-2">Engar tilkynningar</h3>
            <p class="text-gray-600">Það eru engar tilkynningar í boði eins og er.</p>
          </div>
        </div>
      )}
    </div>
  </main>
</Layout>
