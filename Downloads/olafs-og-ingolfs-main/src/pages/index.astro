---
import Layout from '../layouts/Layout.astro'
import {getSiteSettings, getNextService, getAnnouncements} from '../lib/sanity'

const siteSettings = await getSiteSettings()
const title = siteSettings?.canonicalName || siteSettings?.publicName ?? 'Ólafsvík & Ingjaldshóll'
const nextService = await getNextService()
const announcements = await getAnnouncements(3)

function formatDate(dateString: string) {
  const date = new Date(dateString)
  return date.toLocaleString('is-IS', {
    weekday: 'long',
    month: 'long',
    day: 'numeric',
    hour: '2-digit',
    minute: '2-digit'
  })
}

function formatAnnouncementDate(dateString: string) {
  const date = new Date(dateString)
  return date.toLocaleDateString('is-IS', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  })
}
---

<Layout title={title}>
  <main class="min-h-screen bg-gray-50">
    <div class="container mx-auto px-4 py-16">
      <div class="text-center">
        <h1 class="text-4xl font-bold text-gray-900 mb-4">{title}</h1>
        <p class="text-xl text-gray-600">Vefsíða í vinnslu</p>
      </div>
    </div>

    <!-- Announcements -->
    {announcements && announcements.length > 0 && (
      <section class="bg-white py-12">
        <div class="container mx-auto px-4">
          <h2 class="text-2xl font-bold text-gray-900 mb-8 text-center">Tilkynningar</h2>
          <div class="grid gap-6 md:grid-cols-1 lg:grid-cols-3 max-w-6xl mx-auto">
            {announcements.map((announcement) => (
              <div class={`bg-gray-50 rounded-lg p-6 border-l-4 ${
                announcement.pinned ? 'border-blue-500' : 'border-gray-300'
              }`}>
                <div class="flex justify-between items-start mb-3">
                  <h3 class="text-lg font-semibold text-gray-900">{announcement.title}</h3>
                  {announcement.pinned && (
                    <span class="bg-blue-100 text-blue-800 text-xs font-medium px-2.5 py-0.5 rounded">
                      Fest
                    </span>
                  )}
                </div>
                <p class="text-sm text-gray-500 mb-3">{formatAnnouncementDate(announcement.date)}</p>
                <p class="text-gray-700 mb-4 line-clamp-3">{announcement.body}</p>
                {announcement.link && (
                  <a 
                    href={announcement.link} 
                    class="inline-flex items-center text-blue-600 hover:text-blue-800 font-medium text-sm"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    Lesa meira
                    <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                  </a>
                )}
              </div>
            ))}
          </div>
          {announcements.length >= 3 && (
            <div class="text-center mt-8">
              <a 
                href="/tilkynningar" 
                class="inline-block bg-blue-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-blue-700 transition-colors"
              >
                Skoða allar tilkynningar
              </a>
            </div>
          )}
        </div>
      </section>
    )}

    <!-- Next Service Teaser -->
    {nextService && (
      <section class="bg-blue-600 text-white py-12">
        <div class="container mx-auto px-4">
          <div class="text-center">
            <h2 class="text-2xl font-bold mb-4">Næsta guðsthjónusta</h2>
            <div class="bg-white/10 backdrop-blur-sm rounded-lg p-6 max-w-md mx-auto">
              <h3 class="text-xl font-semibold mb-2">{nextService.title}</h3>
              <p class="text-lg mb-1">{formatDate(nextService.startDateTime)}</p>
              <p class="text-lg">{nextService.location}</p>
              {nextService.description && (
                <p class="mt-3 text-sm opacity-90">{nextService.description}</p>
              )}
            </div>
            <a 
              href="/gudsthjonustur" 
              class="inline-block mt-6 bg-white text-blue-600 px-6 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors"
            >
              Skoða allar guðsthjónustur
            </a>
          </div>
        </div>
      </section>
    )}
    
    {siteSettings?.domainPolicyText && (
      <footer class="mt-16 pb-8">
        <div class="container mx-auto px-4">
          <p class="text-center text-sm text-gray-500">
            {siteSettings.domainPolicyText}
          </p>
        </div>
      </footer>
    )}
  </main>
</Layout>
