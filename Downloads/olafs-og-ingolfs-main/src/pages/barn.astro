---
import Layout from '../layouts/Layout.astro'
import {getSiteSettings} from '../lib/sanity'

const showKids = import.meta.env.PUBLIC_SHOW_KIDS === 'true'

if (!showKids) {
  return Astro.redirect('/safnadarstarf')
}

const siteSettings = await getSiteSettings()
const title = siteSettings?.canonicalName ?? siteSettings?.publicName ?? 'Ólafsvík & Ingjaldshóll'
---

<Layout title={`${title} - Barnaefni`}>
  <main class="min-h-screen bg-gray-50">
    <div class="container mx-auto px-4 py-16">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold text-gray-900 mb-4">Barnaefni</h1>
        <p class="text-xl text-gray-600">Skemmtileg efni fyrir börn</p>
      </div>

      <div class="max-w-4xl mx-auto">
        <div class="grid gap-8 md:grid-cols-2">
          <div class="bg-purple-50 rounded-lg shadow-md p-6 border-l-4 border-purple-500">
            <div class="flex items-center mb-4">
              <svg class="w-8 h-8 text-purple-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
              </svg>
              <h2 class="text-xl font-semibold text-gray-900">Biblíusögur</h2>
            </div>
            <p class="text-gray-700 mb-4">
              Skemmtilegar og kennandi sögur úr Biblíunni fyrir börn allra aldra.
            </p>
            <div class="space-y-3">
              <div class="bg-white rounded p-3">
                <h3 class="font-medium text-gray-900">Sagan um Nóa og örkuna</h3>
                <p class="text-sm text-gray-600">Frábær saga um trú og traust.</p>
              </div>
              <div class="bg-white rounded p-3">
                <h3 class="font-medium text-gray-900">Davíð og Gólíat</h3>
                <p class="text-sm text-gray-600">Sagan um hugrekki og trú.</p>
              </div>
              <div class="bg-white rounded p-3">
                <h3 class="font-medium text-gray-900">Jónas og stór fiskurinn</h3>
                <p class="text-sm text-gray-600">Sagan um hlýðni og náða Guðs.</p>
              </div>
            </div>
          </div>

          <div class="bg-purple-50 rounded-lg shadow-md p-6 border-l-4 border-purple-500">
            <div class="flex items-center mb-4">
              <svg class="w-8 h-8 text-purple-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <h2 class="text-xl font-semibold text-gray-900">Skemmtiðir verkefni</h2>
            </div>
            <p class="text-gray-700 mb-4">
              Skemmtileg verkefni og leikir sem læra börn um kristna trú.
            </p>
            <div class="space-y-3">
              <div class="bg-white rounded p-3">
                <h3 class="font-medium text-gray-900">Myndaritun</h3>
                <p class="text-sm text-gray-600">Litad myndir af sögupersónum úr Biblíunni.</p>
              </div>
              <div class="bg-white rounded p-3">
                <h3 class="font-medium text-gray-900">Leikir</h3>
                <p class="text-sm text-gray-600">Spurningaleikir um sögur úr Biblíunni.</p>
              </div>
              <div class="bg-white rounded p-3">
                <h3 class="font-medium text-gray-900">Handverk</h3>
                <p class="text-sm text-gray-600">Gera fallegt handverk tengt trúarsögum.</p>
              </div>
            </div>
          </div>

          <div class="bg-purple-50 rounded-lg shadow-md p-6 border-l-4 border-purple-500">
            <div class="flex items-center mb-4">
              <svg class="w-8 h-8 text-purple-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
              </svg>
              <h2 class="text-xl font-semibold text-gray-900">Bænir fyrir börn</h2>
            </div>
            <p class="text-gray-700 mb-4">
              Einfaldar bænir sem börn geta lært og sagt.
            </p>
            <div class="space-y-3">
              <div class="bg-white rounded p-3">
                <h3 class="font-medium text-gray-900">Morgunbæn</h3>
                <p class="text-sm text-gray-600">Þakka Guði fyrir nýjan dag.</p>
              </div>
              <div class="bg-white rounded p-3">
                <h3 class="font-medium text-gray-900">Kvöldbæn</h3>
                <p class="text-sm text-gray-600">Biðja um vernd og sæla nótt.</p>
              </div>
              <div class="bg-white rounded p-3">
                <h3 class="font-medium text-gray-900">Matarbæn</h3>
                <p class="text-sm text-gray-600">Þakka fyrir mat og næringu.</p>
              </div>
            </div>
          </div>

          <div class="bg-purple-50 rounded-lg shadow-md p-6 border-l-4 border-purple-500">
            <div class="flex items-center mb-4">
              <svg class="w-8 h-8 text-purple-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <h2 class="text-xl font-semibold text-gray-900">Söngvar og lag</h2>
            </div>
            <p class="text-gray-700 mb-4">
              Kristnir söngvar og lög fyrir börn að syngja og spila.
            </p>
            <div class="space-y-3">
              <div class="bg-white rounded p-3">
                <h3 class="font-medium text-gray-900">Barnasálmar</h3>
                <p class="text-sm text-gray-600">Vinsælir barnasálmar með einföldum texta.</p>
              </div>
              <div class="bg-white rounded p-3">
                <h3 class="font-medium text-gray-900">Kristnir söngvar</h3>
                <p class="text-sm text-gray-600">Glöðir söngvar um trú og ást Guðs.</p>
              </div>
              <div class="bg-white rounded p-3">
                <h3 class="font-medium text-gray-900">Lagalisti</h3>
                <p class="text-sm text-gray-600">Yfirlit yfir vinsæla lög fyrir börn.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-purple-100 border-l-4 border-purple-500 p-6 mt-8">
          <h3 class="text-lg font-semibold text-purple-900 mb-2">Foreldrar</h3>
          <p class="text-purple-800">
            Þetta efni er hannað til að hjálpa börnum að læra um kristna trú á skemmtilegan og áhugaverðan hátt. 
            Foreldrar eru hvattir til að kynnast efnið og nota það saman með börnum sínum.
          </p>
        </div>
      </div>
    </div>
  </main>
</Layout>
