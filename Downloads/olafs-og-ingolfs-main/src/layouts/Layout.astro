---
export interface Props {
	title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="is">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <title>{title}</title>
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
        .nav-link {
            @apply px-3 py-2 rounded-md text-sm font-medium transition-colors;
        }
        .nav-link:hover {
            @apply bg-gray-100 text-gray-900;
        }
        .nav-link.active {
            @apply bg-blue-100 text-blue-700;
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav class="bg-white shadow-md">
        <div class="container mx-auto px-4">
            <div class="flex justify-between items-center h-16">
                <div class="flex items-center">
                    <a href="/" class="text-xl font-bold text-gray-900">
                        Ólafsvík & Ingjaldshóll
                    </a>
                </div>
                <div class="hidden md:block">
                    <div class="ml-10 flex items-baseline space-x-4">
                        <a 
                            href="/" 
                            class={`nav-link ${currentPath === '/' ? 'active' : 'text-gray-700'}`}
                        >
                            Heim
                        </a>
                        <a 
                            href="/gudsthjonustur" 
                            class={`nav-link ${currentPath === '/gudsthjonustur' ? 'active' : 'text-gray-700'}`}
                        >
                            Guðsþjónustur
                        </a>
                        <a 
                            href="/athafnir" 
                            class={`nav-link ${currentPath === '/athafnir' ? 'active' : 'text-gray-700'}`}
                        >
                            Athafnir
                        </a>
                        <a 
                            href="/safnadarstarf" 
                            class={`nav-link ${currentPath === '/safnadarstarf' ? 'active' : 'text-gray-700'}`}
                        >
                            Safnaðarstarf
                        </a>
                        <a 
                            href="/tengilidir" 
                            class={`nav-link ${currentPath === '/tengilidir' ? 'active' : 'text-gray-700'}`}
                        >
                            Tengiliðir
                        </a>
                        <a 
                            href="/sogulegt" 
                            class={`nav-link ${currentPath === '/sogulegt' ? 'active' : 'text-gray-700'}`}
                        >
                            Sögulegt efni
                        </a>
                    </div>
                </div>
                <!-- Mobile menu button -->
                <div class="md:hidden">
                    <button class="text-gray-700 hover:text-gray-900 focus:outline-none">
                        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                        </svg>
                    </button>
                </div>
            </div>
        </div>
        <!-- Mobile menu -->
        <div class="md:hidden hidden" id="mobile-menu">
            <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3">
                <a href="/" class="nav-link block text-gray-700">Heim</a>
                <a href="/gudsthjonustur" class="nav-link block text-gray-700">Guðsþjónustur</a>
                <a href="/athafnir" class="nav-link block text-gray-700">Athafnir</a>
                <a href="/safnadarstarf" class="nav-link block text-gray-700">Safnaðarstarf</a>
                <a href="/tengilidir" class="nav-link block text-gray-700">Tengiliðir</a>
                <a href="/sogulegt" class="nav-link block text-gray-700">Sögulegt efni</a>
            </div>
        </div>
    </nav>

    <main>
        <slot />
    </main>
</body>
</html>
